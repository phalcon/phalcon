{
  "name": "phalcon/phalcon",
  "description": "Phalcon Framework",
  "keywords": [
    "php",
    "framework",
    "psr-3",
    "psr-4",
    "psr-7",
    "psr-11",
    "psr-12",
    "psr-16"
  ],
  "license": "MIT",
  "require": {
    "php": ">=8.1 <9.0",
    "ext-fileinfo": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-xml": "*",
    "matthiasmullie/minify": "^1.3",
    "payload-interop/payload-interop": "^1.0",
    "phalcon/traits": "^3.0",
    "psr/container": "^2.0",
    "psr/event-dispatcher": "^1.0",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0"
  },
  "suggest": {
    "ext-apcu": "to use Cache\\Adapter\\Apcu, Storage\\Adapter\\Apcu",
    "ext-gd": "to use Image\\Adapter\\Gd",
    "ext-igbinary": "to use Storage\\Serializer\\Igbinary",
    "ext-imagick": "to use Image\\Adapter\\Imagick",
    "ext-memcached": "to use Cache\\Adapter\\Libmemcached, Session\\Adapter\\Libmemcached, Storage\\Adapter\\Libmemcached",
    "ext-openssl": "to use Encryption\\Crypt",
    "ext-redis": "to use Cache\\Adapter\\Redis, Session\\Adapter\\Redis, Storage\\Adapter\\Redis",
    "ext-yaml": "to use Config\\Adapter\\Yaml"
  },
  "autoload": {
    "psr-4": {
      "Phalcon\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Phalcon\\Tests\\Benchmarks\\": "tests/benchmarks/",
      "Phalcon\\Tests\\": "tests/",
      "Phalcon\\Tests\\Support\\": "tests/support/",
      "Phalcon\\Tests\\Unit\\": "tests/unit/",
      "Phalcon\\Tests\\Database\\": "tests/database/"
    },
    "exclude-from-classmap": [
      "tests/support/assets/"
    ]
  },
  "require-dev": {
    "ext-gettext": "*",
    "ext-yaml": "*",
    "friendsofphp/php-cs-fixer": "^3.95",
    "pds/composer-script-names": "^1.0",
    "pds/skeleton": "^1.0",
    "phalcon/phql": "1.0.x-dev",
    "phalcon/volt": "dev-master",
    "phpbench/phpbench": "^1.4",
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^10.5",
    "predis/predis": "^3.4",
    "squizlabs/php_codesniffer": "^4.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "scripts": {
    "analyze": "vendor/bin/phpstan analyse -c resources/phpstan.neon --memory-limit 1024M",
    "cs": "vendor/bin/phpcs --standard=resources/phpcs.xml",
    "cs-fix": "vendor/bin/phpcbf --standard=resources/phpcs.xml",
    "cs-fixer": "vendor/bin/php-cs-fixer fix --config=resources/php-cs-fixer.php --dry-run --diff",
    "cs-fixer-fix": "vendor/bin/php-cs-fixer fix --config=resources/php-cs-fixer.php",
    "test-unit": "vendor/bin/phpunit -c resources/phpunit.xml.dist",
    "test-unit-coverage": "vendor/bin/phpunit  -c resources/phpunit.xml.dist --coverage-clover tests/_output/coverage.xml",
    "test-unit-coverage-html": "vendor/bin/phpunit  -c resources/phpunit.xml.dist --coverage-html tests/_output/coverage/",
    "test-db-mysql": "vendor/bin/phpunit -c resources/phpunit.mysql.xml",
    "test-db-mysql-coverage": "vendor/bin/phpunit -c resources/phpunit.mysql.xml  --coverage-clover tests/_output/coverage.xml",
    "test-db-mysql-coverage-html": "vendor/bin/phpunit -c resources/phpunit.mysql.xml --coverage-html tests/_output/coverage/",
    "test-db-pgsql": "vendor/bin/phpunit -c resources/phpunit.pgsql.xml",
    "test-db-pgsql-coverage": "vendor/bin/phpunit -c resources/phpunit.pgsql.xml  --coverage-clover tests/_output/coverage.xml",
    "test-db-pgsql-coverage-html": "vendor/bin/phpunit -c resources/phpunit.pgsql.xml --coverage-html tests/_output/coverage/",
    "test-db-sqlite": "vendor/bin/phpunit -c resources/phpunit.sqlite.xml",
    "test-db-sqlite-coverage": "vendor/bin/phpunit -c resources/phpunit.sqlite.xml  --coverage-clover tests/_output/coverage.xml",
    "test-db-sqlite-coverage-html": "vendor/bin/phpunit -c resources/phpunit.sqlite.xml --coverage-html tests/_output/coverage/",
    "test-db": [
      "@test-db-mysql",
      "@test-db-pgsql",
      "@test-db-sqlite"
    ],
    "test-all": [
      "@test-unit",
      "@test-db-mysql",
      "@test-db-pgsql",
      "@test-db-sqlite"
    ]
  },
  "config": {
  }
}
