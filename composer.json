{
  "name": "phalcon/phalcon",
  "description": "Phalcon Framework",
  "keywords": [
    "php",
    "framework"
  ],
  "license": "MIT",
  "require": {
    "php": ">=8.1 <9.0",
    "ext-fileinfo": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-xml": "*",
    "matthiasmullie/minify": "^1.3",
    "phalcon/traits": "^4.0",
    "psr/event-dispatcher": "^1.0"
  },
  "suggest": {
    "ext-apcu": "to use Cache\\Adapter\\Apcu, Storage\\Adapter\\Apcu",
    "ext-gd": "to use Image\\Adapter\\Gd",
    "ext-igbinary": "to use Storage\\Serializer\\Igbinary",
    "ext-imagick": "to use Image\\Adapter\\Imagick",
    "ext-memcached": "to use Cache\\Adapter\\Libmemcached, Session\\Adapter\\Libmemcached, Storage\\Adapter\\Libmemcached",
    "ext-openssl": "to use Encryption\\Crypt",
    "ext-pcntl": "to use signal-based graceful shutdown in Queue\\Consumer\\Worker",
    "ext-redis": "to use Cache\\Adapter\\Redis, Session\\Adapter\\Redis, Storage\\Adapter\\Redis",
    "ext-yaml": "to use Config\\Adapter\\Yaml"
  },
  "autoload": {
    "psr-4": {
      "Phalcon\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Phalcon\\Tests\\Benchmarks\\": "tests/benchmarks/",
      "Phalcon\\Tests\\": "tests/",
      "Phalcon\\Tests\\Support\\": "tests/support/",
      "Phalcon\\Tests\\Unit\\": "tests/unit/",
      "Phalcon\\Tests\\Database\\": "tests/database/"
    },
    "exclude-from-classmap": [
      "tests/support/assets/"
    ]
  },
  "require-dev": {
    "ext-gettext": "*",
    "ext-yaml": "*",
    "friendsofphp/php-cs-fixer": "^3.95",
    "pds/composer-script-names": "^1.0",
    "pds/skeleton": "^1.0",
    "phalcon/phql": "1.0.x-dev",
    "phalcon/talon": "^0.8.0",
    "phalcon/volt": "1.0.x-dev",
    "phpbench/phpbench": "^1.4",
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^10.5",
    "predis/predis": "^3.4",
    "squizlabs/php_codesniffer": "^4.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "scripts": {
    "analyze": "vendor/bin/phpstan analyse -c resources/phpstan.neon --memory-limit 1024M",
    "cs": "vendor/bin/phpcs --standard=resources/phpcs.xml",
    "cs-fix": "vendor/bin/phpcbf --standard=resources/phpcs.xml",
    "cs-fixer": "vendor/bin/php-cs-fixer fix --config=resources/php-cs-fixer.php --dry-run --diff",
    "cs-fixer-fix": "vendor/bin/php-cs-fixer fix --config=resources/php-cs-fixer.php",
    "infection": "vendor/bin/infection --configuration=resources/infection.json5 --threads=max --test-framework-options='--order-by=default'",
    "test-unit": "talon run unit",
    "test-unit-coverage": "talon run unit -- --coverage-clover tests/_output/coverage.xml --coverage-php tests/_output/coverage.cov",
    "test-unit-coverage-html": "talon run unit -- --coverage-html tests/_output/coverage/",
    "test-db-mysql": "talon run mysql",
    "test-db-mysql-coverage": "talon run mysql -- --coverage-clover tests/_output/coverage.xml --coverage-php tests/_output/coverage.cov",
    "test-db-mysql-coverage-html": "talon run mysql -- --coverage-html tests/_output/coverage/",
    "test-db-pgsql": "talon run pgsql",
    "test-db-pgsql-coverage": "talon run pgsql -- --coverage-clover tests/_output/coverage.xml --coverage-php tests/_output/coverage.cov",
    "test-db-pgsql-coverage-html": "talon run pgsql -- --coverage-html tests/_output/coverage/",
    "test-db-sqlite": "talon run sqlite",
    "test-db-sqlite-coverage": "talon run sqlite -- --coverage-clover tests/_output/coverage.xml --coverage-php tests/_output/coverage.cov",
    "test-db-sqlite-coverage-html": "talon run sqlite -- --coverage-html tests/_output/coverage/",
    "test-db": "talon run mysql pgsql sqlite",
    "test-all": "talon run all"
  },
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
